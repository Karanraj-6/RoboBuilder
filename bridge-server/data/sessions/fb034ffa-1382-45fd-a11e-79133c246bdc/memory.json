  "decisions": [],
  "currentPlan": {
    "title": "Functional Airplane System",
    "steps": [
      {
        "id": 1,
        "description": "Construct a basic airplane model in Workspace named 'Airplane'. It must include a 'VehicleSeat' named 'PilotSeat', a 'MainPart' (Anchored = false) as the RootPart, and two physics constraints inside 'MainPart': a 'LinearVelocity' (for forward movement) and an 'AngularVelocity' (for turning/pitching). Ensure the model is grouped.",
        "worker": "MapAgent",
        "dependencies": []
      },
      {
        "id": 2,
        "description": "Create a Folder in ReplicatedStorage named 'AirplaneEvents' containing two RemoteEvents: 'UpdateFlight' and 'ToggleEngine'.",
        "worker": "GameplayAgent",
        "dependencies": []
      },
      {
        "id": 3,
        "description": "Create a server script in ServerScriptService that listens to 'UpdateFlight'. It should update the 'LinearVelocity.VectorVelocity' and 'AngularVelocity.AngularVelocity' of the Airplane's 'MainPart' based on inputs (throttle, steer, pitch) sent from the client.",
        "worker": "GameplayAgent",
        "dependencies": [
          1,
          2
        ]
      },
      {
        "id": 4,
        "description": "Create a LocalScript in StarterPlayerScripts that detects when the player sits in the 'PilotSeat'. While sitting, capture WASD and Arrow Key inputs to calculate throttle and rotation, then fire the 'UpdateFlight' RemoteEvent. Also, implement a basic camera follow offset for flight.",
        "worker": "ClientAgent",
        "dependencies": [
          1,
          2,
          3
        ]
      },
      {
        "id": 5,
        "description": "Create a ScreenGui in StarterGui with a simple HUD showing current 'Speed' (calculated from MainPart.AssemblyLinearVelocity.Magnitude) and 'Altitude'.",
        "worker": "UIAgent",
        "dependencies": [
          1
        ]
      }
    ]
  },
