      {
        "id": 4,
        "description": "Add flight control script to the airplane",
        "area": "Workspace.Airplane",
        "dependencies": [
          3
        ],
        "commands": [
          {
            "type": "insert_script",
            "payload": {
              "name": "FlightController",
              "parent": "Workspace.Airplane",
              "source": "local seat = script.Parent:WaitForChild(\"PilotSeat\")\nlocal fuselage = script.Parent:WaitForChild(\"Fuselage\")\nlocal thrust = fuselage:WaitForChild(\"Thrust\")\nlocal rotation = fuselage:WaitForChild(\"Rotation\")\n\nlocal MAX_SPEED = 100\nlocal TURN_SPEED = 2\nlocal PITCH_SPEED = 1.5\n\nlocal RunService = game:GetService(\"RunService\")\n\nRunService.Heartbeat:Connect(function(dt)\n\tif seat.Occupant then\n\t\t-- W/S controls Pitch (Rotation around X axis)\n\t\t-- A/D controls Yaw (Rotation around Y axis)\n\t\tlocal pitch = seat.Throttle * PITCH_SPEED\n\t\tlocal yaw = -seat.Steer * TURN_SPEED\n\t\t\n\t\t-- Forward movement (Negative Z is forward in Roblox)\n\t\t-- We always fly forward while someone is in the seat\n\t\tthrust.VectorVelocity = Vector3.new(0, 0, -MAX_SPEED)\n\t\trotation.AngularVelocity = Vector3.new(pitch, yaw, 0)\n\t\t\n\t\t-- Anti-gravity: Apply a small upward force to simulate lift if moving\n\t\tthrust.MaxForce = 500000\n\t\trotation.MaxTorque = 500000\n\telse\n\t\t-- Reset forces when no one is sitting\n\t\tthrust.VectorVelocity = Vector3.new(0, 0, 0)\n\t\trotation.AngularVelocity = Vector3.new(0, 0, 0)\n\t\tthrust.MaxForce = 0\n\t\trotation.MaxTorque = 0\n\tend\nend)"
            }
          }
        ]
